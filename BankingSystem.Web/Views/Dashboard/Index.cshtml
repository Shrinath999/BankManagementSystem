<script>

    function toggleCustomers(){

    let hidden = document.getElementById("custValue").innerText.trim();
    let display = document.getElementById("custText");

    if(display.innerText === "••••"){
    display.innerText = hidden;
    }
    else{
    display.innerText = "••••";
    }

    }


    function toggleAccounts(){

    let hidden = document.getElementById("accValue").innerText.trim();
    let display = document.getElementById("accText");

    if(display.innerText === "••••"){
    display.innerText = hidden;
    }
    else{
    display.innerText = "••••";
    }

    }


    function toggleTransactions(){

    let hidden = document.getElementById("txnValue").innerText.trim();
    let display = document.getElementById("txnText");

    if(display.innerText === "••••"){
    display.innerText = hidden;
    }
    else{
    display.innerText = "••••";
    }

    }


    function toggleBalance(){

    let hidden = document.getElementById("balanceValue").innerText.trim();
    let display = document.getElementById("balanceText");

    if(display.innerText.includes("••")){
    display.innerText = hidden;
    }
    else{
    display.innerText = "₹ •••••";
    }

    }

</script>