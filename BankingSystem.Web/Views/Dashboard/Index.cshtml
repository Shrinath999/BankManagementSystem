<div class="dashboard-header mb-4">

    <h2>📊 Banking Dashboard</h2>

    <span class="welcome-text">
        Welcome to Core Banking System
    </span>

</div>


<div class="row g-4 mt-2">

    <div class="col-md-3">
        <div class="stat-card blue" onclick="toggleCustomers()">

            <div class="stat-icon">👤</div>

            <div class="stat-content">
                <p>Total Customers</p>
                <h3 id="custText">••••</h3>

                <span id="custValue" style="display:none">
                    @ViewBag.TotalCustomers
                </span>
            </div>

        </div>
    </div>


    <div class="col-md-3">
        <div class="stat-card green" onclick="toggleAccounts()">

            <div class="stat-icon">💳</div>

            <div class="stat-content">
                <p>Total Accounts</p>
                <h3 id="accText">••••</h3>

                <span id="accValue" style="display:none">
                    @ViewBag.TotalAccounts
                </span>
            </div>

        </div>
    </div>


    <div class="col-md-3">
        <div class="stat-card orange" onclick="toggleTransactions()">

            <div class="stat-icon">💰</div>

            <div class="stat-content">
                <p>Total Transactions</p>
                <h3 id="txnText">••••</h3>

                <span id="txnValue" style="display:none">
                    @ViewBag.TotalTransactions
                </span>
            </div>

        </div>
    </div>


    <div class="col-md-3">
        <div class="stat-card red" onclick="toggleBalance()">

            <div class="stat-icon">🏦</div>

            <div class="stat-content">
                <p>Total Bank Balance</p>
                <h3 id="balanceText">₹ •••••</h3>

                <span id="balanceValue" style="display:none">
                    ₹ @ViewBag.TotalBalance
                </span>

            </div>
        </div>
    </div>

</div>

<hr class="my-5" />


<div class="row g-4">

    <div class="col-md-4">

        <div class="action-card">

            <div class="icon">👤</div>

            <h5>Manage Customers</h5>

            <a asp-controller="Customer" asp-action="Index"
               class="btn btn-primary">
                View Customers
            </a>

        </div>

    </div>



    <div class="col-md-4">

        <div class="action-card">

            <div class="icon">💳</div>

            <h5>Open Account</h5>

            <a asp-controller="Account" asp-action="Create"
               class="btn btn-success">
                Create Account
            </a>

        </div>

    </div>



    <div class="col-md-4">

        <div class="action-card">

            <div class="icon">💸</div>

            <h5>Fund Transfer</h5>

            <a asp-controller="Transaction" asp-action="Transfer"
               class="btn btn-danger">
                Transfer Money
            </a>

        </div>

    </div>

</div>
