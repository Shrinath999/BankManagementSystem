@model IEnumerable<BankingSystem.Entities.Models.Customer>

<style>
    .page-title {
        font-weight: 600;
        margin-bottom: 20px;
        color: #2c3e50;
    }

    .bank-card {
        background: white;
        padding: 25px;
        border-radius: 12px;
        box-shadow: 0 6px 18px rgba(0,0,0,0.08);
        animation: fadeIn 0.6s ease-in-out;
    }

    .btn-add {
        background: #2563eb;
        color: white;
        border: none;
        padding: 8px 16px;
        border-radius: 6px;
        transition: 0.3s;
    }

        .btn-add:hover {
            background: #1d4ed8;
            transform: translateY(-2px);
        }

    table {
        background: white;
    }

        table thead {
            background: #f1f5f9;
        }

        table tbody tr {
            transition: 0.2s;
        }

            table tbody tr:hover {
                background: #f9fafb;
                transform: scale(1.002);
            }

    .customer-img {
        width: 50px;
        height: 50px;
        border-radius: 50%;
        object-fit: cover;
        border: 2px solid #e5e7eb;
    }

    .action-btn {
        border: none;
        padding: 5px 10px;
        border-radius: 6px;
        font-size: 13px;
        transition: 0.2s;
    }

    .btn-edit {
        background: #f59e0b;
        color: white;
    }

        .btn-edit:hover {
            background: #d97706;
            transform: scale(1.05);
        }

    .btn-delete {
        background: #ef4444;
        color: white;
    }

        .btn-delete:hover {
            background: #dc2626;
            transform: scale(1.05);
        }

    @@keyframes fadeIn {
        from

    {
        opacity: 0;
        transform: translateY(10px);
    }

    to {
        opacity: 1;
        transform: translateY(0);
    }

    }
</style>


<div class="container mt-4">

    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2 class="page-title">Customer List</h2>

        <a asp-action="Create" class="btn-add">
            + Add Customer
        </a>
    </div>

    <div class="bank-card">

        <table class="table align-middle table-hover">

            <thead>
                <tr>
                    <th>Name</th>
                    <th>Email</th>
                    <th>Phone</th>
                    <th>Aadhaar</th>
                    <th>PAN</th>
                    <th>Image</th>
                    <th width="140">Actions</th>
                </tr>
            </thead>

            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@item.FullName</td>
                        <td>@item.Email</td>
                        <td>@item.Phone</td>
                        <td>@item.AadhaarNumber</td>
                        <td>@item.PanNumber</td>

                        <td>
                            <img src="~/uploads/customers/@item.ProfileImage"
                                 class="customer-img" />
                        </td>

                        <td>

                            <a asp-action="Edit"
                               asp-route-id="@item.CustomerId"
                               class="action-btn btn-edit">
                                Edit
                            </a>

                            <a asp-action="Delete"
                               asp-route-id="@item.CustomerId"
                               class="action-btn btn-delete"
                               onclick="return confirm('Delete this customer?')">
                                Delete
                            </a>

                        </td>
                    </tr>
                }
            </tbody>

        </table>

    </div>

</div>