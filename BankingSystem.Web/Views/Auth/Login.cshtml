@{
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>Bank Login</title>

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css">

    <style>

        body {
            margin: 0;
            height: 100vh;
            font-family: Segoe UI;
            overflow: hidden;
        }

        /* Animated background */

        .bg {
            position: absolute;
            width: 100%;
            height: 100%;
            background: linear-gradient(-45deg,#2563eb,#0ea5e9,#1e3a8a,#0284c7);
            background-size: 400% 400%;
            animation: gradient 12s ease infinite;
        }

        @@keyframes gradient {
            0%

        {
            background-position: 0% 50%;
        }

        50% {
            background-position: 100% 50%;
        }

        100% {
            background-position: 0% 50%;
        }

        }

        .container-main {
            position: relative;
            height: 100vh;
        }

        .left-panel {
            color: white;
            height: 100vh;
            display: flex;
            flex-direction: column;
            justify-content: center;
            padding: 60px;
        }

            .left-panel h1 {
                font-size: 42px;
                font-weight: bold;
            }

        .login-panel {
            display: flex;
            align-items: center;
            justify-content: center;
            height: 100vh;
        }

        /* Glassmorphism Card */

        .login-card {
            width: 380px;
            padding: 40px;
            border-radius: 16px;
            backdrop-filter: blur(15px);
            background: rgba(255,255,255,0.9);
            box-shadow: 0 10px 40px rgba(0,0,0,0.25);
        }

        .logo {
            width: 60px;
            margin-bottom: 15px;
        }

        .btn-login {
            background: #1d4ed8;
            color: white;
            width: 100%;
            padding: 10px;
            border-radius: 8px;
        }

            .btn-login:hover {
                background: #1e40af;
            }

        .password-box {
            position: relative;
        }

        .toggle-password {
            position: absolute;
            right: 10px;
            top: 8px;
            cursor: pointer;
        }

        .forgot {
            text-align: right;
            font-size: 14px;
        }

    </style>
</head>

<body>

    <div class="bg"></div>

    <div class="container-fluid container-main">
        <div class="row">

            <!-- LEFT PANEL -->

            <div class="col-md-7 left-panel">

                <h1>Faster,<br>More Secure,<br>More Reliable.</h1>

                <p class="mt-4">
                    Welcome to Core Banking System.
                    Securely manage accounts, customers and transactions.
                </p>

            </div>

            <!-- LOGIN PANEL -->

            <div class="col-md-5 login-panel">

                <div class="login-card text-center">

                    <img src="https://cdn-icons-png.flaticon.com/512/2830/2830284.png" class="logo">

                    <h4 class="mb-4">Bank Login</h4>

                    <form method="post" asp-action="Login">

                        <div class="mb-3 text-start">
                            <label>Email</label>
                            <input type="email" name="email" class="form-control" required>
                        </div>

                        <div class="mb-2 text-start password-box">
                            <label>Password</label>

                            <input type="password" id="password" name="password" class="form-control" required>

                            <span class="toggle-password" onclick="togglePassword()">👁</span>

                        </div>

                        <div class="forgot mb-3">
                            <a href="#">Forgot Password?</a>
                        </div>

                        <button type="submit" class="btn btn-login">
                            Login
                        </button>

                    </form>

                </div>

            </div>

        </div>
    </div>

    <script>

        function togglePassword(){

        var x = document.getElementById("password");

        if(x.type === "password"){
        x.type = "text";
        }
        else{
        x.type = "password";
        }

        }

    </script>

</body>
</html>