

@{
    ViewData["Title"] = "Deposit";
}

<div class="container mt-4">

    <div class="row justify-content-center">
        <div class="col-md-6">

            <div class="card shadow-lg border-0">
                <div class="card-header bg-success text-white text-center">
                    <h4 class="mb-0">💰 Deposit Money</h4>
                </div>

                <div class="card-body p-4">

                    @if (ViewBag.Error != null)
                    {
                        <div class="alert alert-danger text-center">
                            @ViewBag.Error
                        </div>
                    }

                    <form asp-action="Deposit" method="post">

                        <!-- Account Selection -->
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Select Account</label>
                            <select name="accountId" class="form-select" required>
                                <option value="">-- Select Account --</option>
                                @foreach (var account in ViewBag.Accounts)
                                {
                                    <option value="@account.AccountId">
                                        @account.Customer?.FullName - @account.AccountNumber (@account.AccountType)
                                    </option>
                                }
                            </select>
                        </div>

                        <!-- Amount -->
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Enter Amount</label>
                            <div class="input-group">
                                <span class="input-group-text">₹</span>
                                <input type="number"
                                       step="0.01"
                                       name="amount"
                                       class="form-control"
                                       placeholder="Enter deposit amount"
                                       required />
                            </div>
                        </div>

                        <!-- Quick Amount Buttons -->
                        <div class="mb-3 text-center">
                            <button type="button" class="btn btn-outline-success btn-sm m-1" onclick="setAmount(1000)">₹ 1000</button>
                            <button type="button" class="btn btn-outline-success btn-sm m-1" onclick="setAmount(5000)">₹ 5000</button>
                            <button type="button" class="btn btn-outline-success btn-sm m-1" onclick="setAmount(10000)">₹ 10000</button>
                        </div>

                        <!-- Submit -->
                        <div class="d-grid">
                            <button type="submit" class="btn btn-success btn-lg">
                                Confirm Deposit
                            </button>
                        </div>

                    </form>

                </div>
            </div>

        </div>
    </div>

</div>

@section Scripts {
    <script>
        function setAmount(value) {
            document.querySelector('input[name="amount"]').value = value;
        }
    </script>
}